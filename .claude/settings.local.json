  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "lvgl-simulator"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__lvgl-simulator__lvgl_render|mcp__lvgl-simulator__lvgl_render_full",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p /app/esphome1/mocks && src=/usr/lib/node_modules/lvgl-mcp-server/simulator/build/output/screenshot.png; [ -f \"$src\" ] && cp \"$src\" \"/app/esphome1/mocks/lvgl_$(date +%Y%m%d_%H%M%S).png\" 2>/dev/null || true",
            "statusMessage": "Saving PNG to mocks/..."
          }
        ]
      }
    ]
  }
